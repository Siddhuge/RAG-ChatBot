# ====================================================================
# Enterprise RAG Chatbot — configuration
# Copy to .env and fill in. NEVER commit your real .env.
# ====================================================================

# --- Claude / Anthropic (required) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6
MAX_TOKENS=2048
# Enable adaptive thinking for harder reasoning (slower, costs more). Default off.
ENABLE_THINKING=false

# --- Embeddings (local, free — no key needed) ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- Vector store (Qdrant) ---
# Inside docker-compose, use http://qdrant:6333
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=                 # set if your Qdrant requires auth
QDRANT_COLLECTION=documents

# --- Ingestion / retrieval ---
DATA_DIR=./data
CHUNK_SIZE=512                     # approx tokens per chunk
CHUNK_OVERLAP=64
TOP_K=5
SCORE_THRESHOLD=0.3

# --- API server ---
LOG_LEVEL=INFO
# Comma-separated API keys. If empty, the API is OPEN (dev only).
APP_API_KEYS=
# Comma-separated allowed CORS origins, or * for all.
CORS_ORIGINS=*

# --- Clients (CLI + Streamlit UI) ---
# Where the CLI/UI find the API. In docker-compose the UI overrides this to
# http://api:8000 automatically.
RAG_API_URL=http://localhost:8000
# Must match one of APP_API_KEYS when auth is enabled.
RAG_API_KEY=
